POSTGRES_PASSWORD=

# ==========================================
# APLICAÇÕES: CREDENCIAIS DE BANCO E CHAVES
# ==========================================
# N8N
N8N_DB_PASS=
N8N_ENCRYPTION_KEY=

# ODOO
ODOO_DB_PASS=

# WINDMILL
WINDMILL_DB_PASS=

# CHATWOOT
CHATWOOT_DB_PASS=
CHATWOOT_SECRET=cole_aqui_a_chave_gerada_com_openssl

# ------------------------------
# TYPEBOT CONFIGS
# ------------------------------
TYPEBOT_DB_PASS=senha_typebot_123

# URLs do Typebot (Devem ser EXATAMENTE como configuradas no NPM)
