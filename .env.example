# ==========================================
# CONFIGURAÇÕES DO CLIENTE
# ==========================================
CLIENTE_NOME=nome_do_cliente
DOMINIO_BASE=000.000.000.000.nip.io

# ==========================================
# INFRAESTRUTURA: BANCO DE DADOS CENTRAL
# ==========================================
